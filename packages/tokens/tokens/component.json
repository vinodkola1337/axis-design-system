    "footer-gap":             { "$value": "{spacing.2}",                 "$type": "dimension" },
    "padding": {
      "sm":                   { "$value": "{spacing.3}",                 "$type": "dimension" },
      "md":                   { "$value": "{spacing.4}",                 "$type": "dimension" },
      "lg":                   { "$value": "{spacing.5}",                 "$type": "dimension" }
