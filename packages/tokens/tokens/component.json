    "title-font-size":        { "$value": "{font.size.lg}",              "$type": "dimension" },
    "title-font-weight":      { "$value": "{font.weight.semibold}",      "$type": "fontWeight" },
    "title-line-height":      { "$value": "{font.line-height.snug}",     "$type": "number" },
    "subtitle-font-size":     { "$value": "{font.size.sm}",              "$type": "dimension" },
    "subtitle-line-height":   { "$value": "{font.line-height.normal}",   "$type": "number" },
    "body-font-size":         { "$value": "{font.size.base}",            "$type": "dimension" },
    "body-line-height":       { "$value": "{font.line-height.normal}",   "$type": "number" },
    "disabled-opacity":       { "$value": "{opacity.disabled}",          "$type": "number" }
  },
  "label": {
    "gap":                 { "$value": "{spacing.1}",              "$type": "dimension" },
    "color-text":          { "$value": "{color.text.primary}",     "$type": "color" },
