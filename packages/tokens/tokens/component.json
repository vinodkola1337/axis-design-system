{
  "button": {
    "border-radius":        { "$value": "{border-radius.md}",        "$type": "dimension" },
    "border-width":         { "$value": "{border-width.1}",          "$type": "dimension" },
    "disabled-opacity":     { "$value": "{opacity.disabled}",         "$type": "number" },
    "focus-ring-color":     { "$value": "{color.border.focus}",      "$type": "color" },
    "focus-ring-width":     { "$value": "{border-width.2}",          "$type": "dimension" },
    "font-weight":          { "$value": "{font.weight.semibold}",    "$type": "fontWeight" },
    "size": {
      "sm": {
        "height":           { "$value": "{spacing.8}",              "$type": "dimension" },
        "padding-x":        { "$value": "{spacing.3}",              "$type": "dimension" },
        "font-size":        { "$value": "{font.size.sm}",           "$type": "dimension" }
      },
      "md": {
        "height":           { "$value": "{spacing.10}",             "$type": "dimension" },
        "padding-x":        { "$value": "{spacing.4}",              "$type": "dimension" },
        "font-size":        { "$value": "{font.size.base}",         "$type": "dimension" }
      },
      "lg": {
        "height":           { "$value": "{spacing.12}",             "$type": "dimension" },
        "padding-x":        { "$value": "{spacing.5}",              "$type": "dimension" },
        "font-size":        { "$value": "{font.size.lg}",           "$type": "dimension" }
      }
    },
    "primary": {
      "color-bg":           { "$value": "{color.interactive.primary}",        "$type": "color" },
      "color-bg-hover":     { "$value": "{color.interactive.primary-hover}",  "$type": "color" },
      "color-bg-active":    { "$value": "{color.interactive.primary-active}", "$type": "color" },
      "color-border":       { "$value": "{color.interactive.primary}",        "$type": "color" },
      "color-text":         { "$value": "{color.text.inverse}",              "$type": "color" }
    },
    "secondary": {
      "color-bg":           { "$value": "{color.surface.default}",           "$type": "color" },
      "color-bg-hover":     { "$value": "{color.interactive.primary-subtle}", "$type": "color" },
      "color-bg-active":    { "$value": "{color.background.subtle}",         "$type": "color" },
      "color-border":       { "$value": "{color.border.default}",            "$type": "color" },
      "color-text":         { "$value": "{color.interactive.primary}",       "$type": "color" }
    },
    "ghost": {
      "color-bg":           { "$value": "{color.transparent}",               "$type": "color" },
      "color-bg-hover":     { "$value": "{color.interactive.primary-subtle}", "$type": "color" },
      "color-bg-active":    { "$value": "{color.background.subtle}",         "$type": "color" },
      "color-border":       { "$value": "{color.transparent}",               "$type": "color" },
      "color-text":         { "$value": "{color.interactive.primary}",       "$type": "color" }
    }
  },
  "input": {
    "height":              { "$value": "{spacing.10}",             "$type": "dimension" },
    "padding-x":           { "$value": "{spacing.3}",              "$type": "dimension" },
    "border-radius":       { "$value": "{border-radius.md}",       "$type": "dimension" },
    "border-color":        { "$value": "{color.border.default}",   "$type": "color" },
    "border-color-focus":  { "$value": "{color.border.focus}",     "$type": "color" },
    "color-bg":            { "$value": "{color.surface.default}",  "$type": "color" },
    "color-text":          { "$value": "{color.text.primary}",     "$type": "color" },
    "color-placeholder":   { "$value": "{color.text.placeholder}", "$type": "color" }
  }
}
