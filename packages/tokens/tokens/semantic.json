{
  "color": {
    "background": {
      "default": { "$value": "{color.gray.50}",  "$type": "color" },
      "subtle":   { "$value": "{color.gray.100}", "$type": "color" },
      "inverse":  { "$value": "{color.gray.900}", "$type": "color" }
    },
    "surface": {
      "default": { "$value": "{color.white}",    "$type": "color" },
      "raised":  { "$value": "{color.gray.50}",  "$type": "color" },
      "overlay": { "$value": "{color.gray.100}", "$type": "color" }
    },
    "text": {
      "primary":     { "$value": "{color.gray.900}", "$type": "color" },
      "secondary":   { "$value": "{color.gray.600}", "$type": "color" },
      "placeholder": { "$value": "{color.gray.400}", "$type": "color" },
      "disabled":    { "$value": "{color.gray.300}", "$type": "color" },
      "inverse":     { "$value": "{color.white}",    "$type": "color" },
      "link":        { "$value": "{color.blue.600}", "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.gray.200}", "$type": "color" },
      "strong":  { "$value": "{color.gray.400}", "$type": "color" },
      "focus":   { "$value": "{color.blue.500}", "$type": "color" }
    },
    "interactive": {
      "primary":        { "$value": "{color.blue.600}", "$type": "color" },
      "primary-hover":  { "$value": "{color.blue.700}", "$type": "color" },
      "primary-active": { "$value": "{color.blue.800}", "$type": "color" },
      "primary-subtle": { "$value": "{color.blue.50}",  "$type": "color" }
    },
    "feedback": {
      "error":          { "$value": "{color.red.600}",   "$type": "color" },
      "error-hover":    { "$value": "{color.red.700}",   "$type": "color" },
      "error-active":   { "$value": "{color.red.800}",   "$type": "color" },
      "error-subtle":   { "$value": "{color.red.50}",    "$type": "color" },
      "success":        { "$value": "{color.green.500}", "$type": "color" },
      "success-subtle": { "$value": "{color.green.50}",  "$type": "color" },
      "warning":        { "$value": "{color.amber.500}", "$type": "color" },
      "warning-subtle": { "$value": "{color.amber.50}",  "$type": "color" }
    }
  },
  "opacity": {
    "disabled": { "$value": "{opacity.50}", "$type": "number" }
  }
}
