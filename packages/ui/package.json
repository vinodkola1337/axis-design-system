{
  "name": "@vinodkola/axis-ui",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./button": {
      "import": "./dist/button.js",
      "types": "./dist/button.d.ts"
    },
    "./label": {
      "import": "./dist/label.js",
      "types": "./dist/label.d.ts"
    },
    "./text-input": {
      "import": "./dist/text-input.js",
      "types": "./dist/text-input.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist --noEmit false",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@storybook/vue3-vite": "10.4.2",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@vinodkola/axis-tokens": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
